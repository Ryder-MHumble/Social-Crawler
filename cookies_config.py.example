#!/usr/bin/env python
# -*- coding: utf-8 -*-
"""
Cookie 配置文件模板
将此文件复制为 cookies_config.py 并填写您的 Cookie

获取 Cookie 的方法请查看 COOKIE_GUIDE.md
"""

# ==================== Cookie 配置 ====================

# 小红书 Cookie
# 登录小红书网页版后，按 F12 打开开发者工具，复制 Cookie
XHS_COOKIE = ""

# 抖音 Cookie
# 登录抖音网页版后，按 F12 打开开发者工具，复制 Cookie
DOUYIN_COOKIE = ""

# Bilibili Cookie
# 登录 B 站网页版后，按 F12 打开开发者工具，复制 Cookie
BILIBILI_COOKIE = ""

# 微博 Cookie
# 登录微博网页版后，按 F12 打开开发者工具，复制 Cookie
WEIBO_COOKIE = ""

# 快手 Cookie
# 登录快手网页版后，按 F12 打开开发者工具，复制 Cookie
KUAISHOU_COOKIE = ""

# ==================== Cookie 映射 ====================

COOKIES = {
    "xhs": XHS_COOKIE,
    "dy": DOUYIN_COOKIE,
    "bili": BILIBILI_COOKIE,
    "wb": WEIBO_COOKIE,
    "ks": KUAISHOU_COOKIE,
}


# ==================== 辅助函数 ====================

def get_cookie(platform: str) -> str:
    """
    获取指定平台的 Cookie

    Args:
        platform: 平台代码 (xhs, dy, bili, wb, ks)

    Returns:
        str: Cookie 字符串，如果未配置则返回空字符串
    """
    return COOKIES.get(platform, "")


def is_cookie_configured(platform: str) -> bool:
    """
    检查平台 Cookie 是否已配置

    Args:
        platform: 平台代码

    Returns:
        bool: True 表示已配置
    """
    cookie = get_cookie(platform)
    return bool(cookie and cookie.strip())


def get_all_configured_platforms():
    """
    获取所有已配置 Cookie 的平台

    Returns:
        list: 已配置的平台列表
    """
    return [platform for platform in COOKIES.keys() if is_cookie_configured(platform)]
